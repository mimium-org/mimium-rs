// @test {"times":1,"stereo":false,"expected":[11.0],"web":true}

#stage(macro)
fn scalar(){
  let x = 2.0 + 3.0
  x |> lift
}
fn array(){
  let arr = [1.0, 2.0, 3.0]
  arr |> lift
}
#stage(main)
fn dsp(){
  let s = scalar!()
  let a = array!()
  s + a[0] + a[1] + a[2] // 5.0 + 1.0 + 2.0 + 3.0 = 11.0
}
