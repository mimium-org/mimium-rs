// @test {"times":10,"stereo":false,"expected":[0.6000000000000001, 1.2000000000000002, 1.8000000000000003, 2.4000000000000004, 3.0, 3.5999999999999996, 4.199999999999999, 4.8, 5.3999999999999995, 5.999999999999999],"web":true,"tol":1e-12}
fn counter(inc:float){
    self+inc
}

fn replicate(n:float,gen:()->(float)->float){
    if (n>0.0){
        let c = replicate(n - 1.0,gen)
        let g = gen()
        |x| {g(x) * n + c(x)}
    }else{
        |x| { 0.0 }
    }
}
let mycounter = replicate(3.0,| |counter);
fn dsp(){
    mycounter(0.1)
}