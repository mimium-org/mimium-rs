// @test {"times":10,"stereo":false,"expected":[20.3, 20.599999999999998, 20.900000000000002, 21.2, 21.5, 21.8, 22.099999999999998, 22.400000000000002, 22.7, 23.0],"web":true}
fn mycount(rate){
 self+ rate*0.1
}

fn hof(counter:()->(float)->float){
  let c1 = counter();
  let c2 = counter();
 |x| {x + c1(1.0) + c2(2.0)}
}
let myfilter = hof(| |mycount)
fn dsp(){
  myfilter(20.0)
}