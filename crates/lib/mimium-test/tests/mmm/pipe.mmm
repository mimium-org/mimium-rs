// @test {"times":1,"stereo":true,"expected":[102.0, 102.0],"web":true}
// pipe operators can be placed at either the beginning or the end of the line
// `||>` works with underscore-based macro partial application
fn dsp(){
    let x = 3.0 ||>
        1.0 + _ ||>
        _ / 2.0 ||>
        _ + 100.0

    let y = 3.0
        |> |arg| 1.0 + arg
        |> |arg| arg / 2.0
        |> |arg| arg + 100.0

    (x, y)
}
