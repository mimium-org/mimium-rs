`{
let pi = 3.14159265359
let sr = 48000.0
let phasor= |freq|{
  (self + freq/sr)%1.0
}
let osc = |freq|{
  sin(phasor(freq)*pi*2.0)
}
let fmosc = |freq,rate|{
  osc(freq + osc(rate)*4000.0)
}
let amosc = |input,rate|{
   input * (osc(rate)+1.0/ 2)
}

let dsp = | |{
    let l = amosc(fmosc(440,0.02) , 0.2)* Control!("gain",0.5)
    let r = amosc(fmosc(220,0.03) , 0.3)* Control!("gain2",0.5)
    (l,r) |> Probe!("out")
}
}