//Sampler_mono! returns a record with a player closure and sample length
fn counter(){
    self+1.0 
}
//add -1.0 offset so that the counter start from 0 at t=0
fn dsp(){
    let sampler = Sampler_mono!("tests/assets/count_100_by_0_01_f32_48000Hz.wav")
    let player = sampler.player
    player(counter()-1.0)
}