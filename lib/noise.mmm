#stage(macro)
let RANDMAX	= 2147483647.0
fn urand_counter(){
    let x = 10 //global global seed
    | | {
        x = x+1
        lift_f(x)
    }
}
let global_seed:()->`float = urand_counter()
#stage(main)
//linear congruence
fn gen_rand(seed){
     (self*48271.0) % (2.0^31.0 -1.0)+seed
}
fn gen_noise(seed){
    gen_rand(seed)/$(lift_f(RANDMAX))
}
pub fn noise(){
    gen_noise(1.0)
}
#stage(macro)
pub fn unoise(){
    `(gen_noise($(global_seed())))
}
pub fn white(){
    `(unoise!() *2 - 1)
}