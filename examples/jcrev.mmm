use osc::{phasor,sinwave}
use env::adsr
use reverb::{jcrev,freeverb_mono,freeverb_stereo}


let osc = |f| sinwave({freq=f})
let osc01 = |f| (osc(f) + 1) /2.0
fn dsp(){
  let gate =(phasor(7,0)>0.95)
  let src = osc(phasor(1.1,0)*400+100) 
        * adsr({gate= gate ,attack = 0.0001,release=0.01})
  let mix = osc01(0.6)
  let r  = ( jcrev(src,2.0,1) ) |> (|x|(x,x))
  // let r = freeverb_stereo((src,src),0.8,0.6,1,1)
  r*0.2 |> ProbeValue!("out")
}