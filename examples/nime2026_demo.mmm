use core::*
use osc::*
use delay::*
use env::*
let notes = [60,62,64,67]
fn changed(i){
	i > mem(i)
}

fn melody(cps){
	let len =length_array(notes)
	let phase = phasor(cps/(len-1),0)|> ProbeValue!("test")
	let i = phase*len |> floor
	let freq = notes[i]|>midi_to_hz
	let gate = adsr({gate= (phase*len%1) < 0.2})
	saw(freq,0)*gate
}

let cps = 0.9
fn dsp(){
	let s = melody(cps)
	let s = pingpong_delay((s,s),0.5,0.9,1.0,0.5) 
	s |> ProbeValue!("out")
}